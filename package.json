{
  "name": "agents-wizard",
  "version": "0.1.0",
  "description": "Interactive AGENTS.md generator",
  "type": "module",
  "bin": { "agents-wizard": "./dist/cli.js" },
  "files": ["dist", "questions.yaml", "README.md"],
  "packageManager": "pnpm@11.11.0",
  "engines": { "node": ">=22" },
  "scripts": {
    "check": "biome check . && tsc --noEmit",
    "test": "vitest run",
    "build": "tsup src/cli.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.0.1",
    "env-paths": "^3.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
